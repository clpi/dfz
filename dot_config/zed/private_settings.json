    "inline_completion_provider": "copilot",
    "copilot": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "close_position": "right"
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "closureReturnTypeHints": {
            "enable": "always"
          },
          "lifetimeElisionHints": {
            "enable": "always",
            "useParameterNames": true,
            "enableForFunctionsWithoutImpl": true
          },
          "parameterHints": {
            "enable": "always"
          }
        },
        "cargo": {
          "loadOutDirsFromCheck": true
        }
      }
    },
    "clangd": {
      "binary": {
        "path": "/usr/bin/clangd",
        "arguments": []
      }
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict"
        },
        "python": {
          "pythonPath": "/opt/homebrew/bin/python3"
        }
      }
    }
  },
  "copilot": {
    "enabled": true
  },
  "terminal": {
    "button": true,
    "line_height": "standard",
    "env": {},
    "font_family": "IosevkaTerm Nerd Font",
    "toolbar": {
